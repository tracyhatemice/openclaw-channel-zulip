{
  "name": "openclaw-channel-zulip",
  "version": "2026.4.9",
  "description": "Zulip channel plugin for OpenClaw — concurrent message processing, reaction indicators, file uploads, and full actions API",
  "type": "module",
  "author": "FtlC-ian",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-channel",
    "zulip",
    "chatbot",
    "bot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FtlC-ian/openclaw-channel-zulip.git"
  },
  "homepage": "https://github.com/FtlC-ian/openclaw-channel-zulip#readme",
  "bugs": {
    "url": "https://github.com/FtlC-ian/openclaw-channel-zulip/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "openclaw": "^2026.3.28",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "zulip",
      "label": "Zulip",
      "selectionLabel": "Zulip (plugin)",
      "docsLabel": "zulip",
      "blurb": "Zulip streams/topics with reaction-based reply indicators (plugin, installed separately).",
      "order": 70
    },
    "install": {
      "npmSpec": "openclaw-channel-zulip",
      "defaultChoice": "npm"
    }
  }
}
